# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ai-x
POSTGRES_PASSWORD=changeme
POSTGRES_DB=acl_FIRDI
POSTGRES_PORT=5435

PG_DSN=dbname=acl_FIRDI user=ai-x password=changeme host=postgres port=5432
TENANT_ID=firdi

# ─── Keycloak (webhook-service) ───────────────────────────────
KEYCLOAK_URL=https://your-keycloak-host/
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=user-sync-service
KEYCLOAK_CLIENT_SECRET=your-client-secret
WEBHOOK_SECRET=firdi-webhook-secret-changeme

# ─── ACL (admin-api) ──────────────────────────────────────────
ACL_ADMIN_SECRET=acl-admin-secret-changeme

# ─── Ingest worker URL (admin-api → ingest-worker) ────────────
INGEST_WORKER_URL=http://ingest-worker:8762

# ─── Marker service / LiteLLM proxy ───────────────────────────
MARKER_SERVICE_URL=http://marker-service:8766
LITELLM_PROXY_URL=http://litellm-proxy:4000
LITELLM_API_KEY=sk-litellm-internal

# ─── LLM / Embedding (all services) ──────────────────────────
OLLAMA_BASE_URL=http://your-ollama-host:11434
OLLAMA_GEN_URL=http://your-ollama-host:11434/api/generate
EMBED_MODEL=bge-m3
SEG_MODEL=qwen3:8b
SUMMARY_MODEL=qwen3:8b

# ─── Model offline mode (HuggingFace) ─────────────────────────
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ─── Logging ──────────────────────────────────────────────────
LOG_DIR=logs
