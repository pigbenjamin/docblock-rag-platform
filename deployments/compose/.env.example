# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ai-x
POSTGRES_PASSWORD=changeme
POSTGRES_DB=acl_FIRDI
POSTGRES_PORT=5435

PG_DSN=dbname=acl_FIRDI user=ai-x password=changeme host=postgres port=5432
TENANT_ID=firdi

# ─── Keycloak (webhook-service) ───────────────────────────────
# 容器內連宿主機的 Keycloak 請用 host.docker.internal
KEYCLOAK_URL=https://your-keycloak-host:8446
# realm 名稱區分大小寫
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=user-sync-service
KEYCLOAK_CLIENT_SECRET=your-client-secret
# true / false / CA bundle 路徑（自簽憑證環境用）
KEYCLOAK_VERIFY_SSL=true
WEBHOOK_SECRET=firdi-webhook-secret-changeme

# ─── ACL (document-api) ──────────────────────────────────────────
ACL_ADMIN_SECRET=acl-admin-secret-changeme

# ─── Ingest worker URL (document-api → ingest-worker) ────────────
INGEST_WORKER_URL=http://ingest-worker:8762

# ─── LiteLLM（marker/pdf-to-md 路由，由外部 LiteLLM 提供）────────
LITELLM_PROXY_URL=http://your-litellm-host:4000
LITELLM_API_KEY=sk-litellm-internal

# ─── LLM / Embedding (all services, OpenAI-compatible LiteLLM) ─
LITELLM_BASE_URL=http://your-litellm-host:4000
OLLAMA_BASE_URL=http://your-litellm-host:4000
EMBED_MODEL=embeddinggemma-300m
# EmbeddingGemma task prompts（serving 端已自動加前綴時設成空字串；引號保留結尾空格）
EMBED_QUERY_PREFIX="task: search result | query: "
EMBED_DOC_PREFIX="title: none | text: "
SEG_MODEL=gemma-4-26B-A4B-it
SUMMARY_MODEL=gemma-4-26B-A4B-it
CHAT_MODEL=gemma-4-26B-A4B-it
CAPABILITIES_MODEL=gemma-4-26B-A4B-it
# rerank 服務已移除；留空時 rerank 失敗自動 fallback 原始排序
RERANK_MODEL=

# ─── Model offline mode (HuggingFace) ─────────────────────────
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ─── Logging ──────────────────────────────────────────────────
LOG_DIR=logs
